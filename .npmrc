@poukai-inc:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NPM_TOKEN}

# pnpm 10 default flipped link-workspace-packages to false. We rely on
# the dual-consumption model: locally a parent pnpm-workspace.yaml lists
# both repos, pnpm should prefer the workspace @poukai-inc/ui. In CI
# there's no workspace, so this setting has no effect and pnpm fetches
# from the registry above.
link-workspace-packages=true
